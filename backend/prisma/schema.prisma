generator client {
  provider        = "prisma-client-js"
  connectionLimit = 25
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Feature {
  id                       String                    @id @default(cuid())
  code                     String                    @unique
  name                     String
  description              String?
  module                   String
  isCore                   Boolean                   @default(false)
  sortOrder                Int                       @default(0)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  deletedAt                DateTime?
  deviceOverrides          DeviceFeatureOverride[]
  dependedBy               FeatureDependency[]       @relation("FeatureDependedBy")
  featureDependencies      FeatureDependency[]       @relation("FeatureDependencies")
  featurePermissions       FeaturePermission[]
  subscriptionPlanFeatures SubscriptionPlanFeature[]

  @@index([module])
  @@index([isCore])
  @@map("features")
}

model FeatureDependency {
  id          String  @id @default(cuid())
  featureId   String
  dependsOnId String
  dependsOn   Feature @relation("FeatureDependedBy", fields: [dependsOnId], references: [id], onDelete: Cascade)
  feature     Feature @relation("FeatureDependencies", fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([featureId, dependsOnId])
  @@map("feature_dependencies")
}

model FeaturePermission {
  id           String     @id @default(cuid())
  featureId    String
  permissionId String
  feature      Feature    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([featureId, permissionId])
  @@map("feature_permissions")
}

model Permission {
  id                    String                 @id @default(cuid())
  code                  String                 @unique
  name                  String
  description           String?
  module                String
  isSystem              Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  accountPermissions    AccountPermission[]
  deviceTypePermissions DeviceTypePermission[]
  featurePermissions    FeaturePermission[]
  employeePermissions   EmployeePermission[]

  @@index([module])
  @@map("permissions")
}

model DeviceTypePermission {
  id           String        @id @default(cuid())
  deviceType   PosDeviceType
  permissionId String
  isRequired   Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  permission   Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([deviceType, permissionId])
  @@index([deviceType])
  @@map("device_type_permissions")
}

model DeviceFeatureOverride {
  id        String   @id @default(cuid())
  deviceId  String
  featureId String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([deviceId, featureId])
  @@index([deviceId])
  @@map("device_feature_overrides")
}

model AccountPermission {
  id           String     @id @default(cuid())
  accountId    String
  permissionId String
  allowed      Boolean    @default(true)
  grantedBy    String?
  createdAt    DateTime   @default(now())
  expiresAt    DateTime?
  account      Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([accountId, permissionId])
  @@index([accountId])
  @@index([expiresAt])
  @@map("account_permissions")
}

model SubscriptionPlan {
  id              String                      @id @default(cuid())
  code            String                      @unique
  name            String
  description     String?
  price           Decimal                     @db.Decimal(12, 2)
  billingInterval SubscriptionBillingInterval @default(MONTHLY)
  durationDays    Int                         @default(30)
  isActive        Boolean                     @default(true)
  planFeatures    SubscriptionPlanFeature[]
  subscriptions   Subscription[]
  invitations     BranchInvitation[]

  @@index([isActive])
  @@index([billingInterval])
  @@map("subscription_plans")
}

model SubscriptionPlanFeature {
  id                 String           @id @default(cuid())
  subscriptionPlanId String
  featureId          String
  feature            Feature          @relation(fields: [featureId], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Cascade)

  @@unique([subscriptionPlanId, featureId])
  @@map("subscription_plan_features")
}

model Subscription {
  id          String             @id @default(cuid())
  branchId    String
  planId      String
  status      SubscriptionStatus @default(TRIAL)
  startDate   DateTime
  endDate     DateTime
  trialEndsAt DateTime?
  cancelledAt DateTime?
  autoRenew   Boolean            @default(true)
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  invoices    BillingInvoice[]
  plan        SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([endDate])
  @@index([trialEndsAt])
  @@index([branchId, status])
  @@map("subscriptions")
}

model BillingInvoice {
  id             String       @id @default(cuid())
  subscriptionId String
  invoiceNumber  String       @unique
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @default("VND")
  status         String       @default("PENDING")
  paidAt         DateTime?
  dueDate        DateTime
  paidAmount     Decimal?     @db.Decimal(12, 2)
  paymentMethod  String?
  notes          String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@map("billing_invoices")
}

model Table {
  id                String        @id @default(cuid())
  accountId         String
  tableCode         String
  tableName         String?
  capacity          Int
  status            TableStatus   @default(AVAILABLE)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  tableType         TableType     @default(POOL)
  posX              Float         @default(0)
  posY              Float         @default(0)
  hourlyRate        Decimal       @default(0) @db.Decimal(12, 2)
  isMerged          Boolean       @default(false)
  mergedIntoTableId String?
  mode              TableMode     @default(BILLIARD)
  orders            Order[]       @relation("TableOrders")
  sessions          PlaySession[]
  reservations      Reservation[]
  tables            Table?        @relation("tablesTotables", fields: [mergedIntoTableId], references: [id])
  other_tables      Table[]       @relation("tablesTotables")

  @@unique([accountId, tableCode])
  @@unique([accountId, tableCode], map: "tables_branchId_tableCode_key")
  @@index([accountId])
  @@index([accountId], map: "tables_branchId_idx")
  @@index([mergedIntoTableId])
  @@map("tables")
}

model PlaySession {
  id              String            @id @default(cuid())
  tableId         String
  startTime       DateTime
  expectedEndTime DateTime
  endTime         DateTime?
  durationMinutes Int               @default(0)
  tableFee        Decimal           @default(0) @db.Decimal(12, 2)
  status          PlaySessionStatus @default(PLAYING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  order           Order?            @relation("SessionOrder")
  table           Table             @relation(fields: [tableId], references: [id])

  @@index([tableId])
  @@index([status])
  @@index([tableId, status])
  @@map("play_sessions")
}

model Reservation {
  id              String            @id @default(cuid())
  tableId         String
  branchId        String
  customerName    String
  phone           String?
  reservationTime DateTime?
  durationMinutes Int?
  note            String?
  status          ReservationStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  table           Table             @relation(fields: [tableId], references: [id])

  @@index([tableId])
  @@index([status])
  @@index([reservationTime])
  @@index([branchId, status])
  @@map("reservations")
}

model Account {
  id                                  String                       @id @default(cuid())
  email                               String                       @unique
  password                            String
  pinCode                             String?
  fullName                            String
  phone                               String?
  avatarUrl                           String?
  status                              AccountStatus                @default(ACTIVE)
  mustChangePassword                  Boolean                      @default(true)
  active                              Boolean                      @default(true)
  createdAt                           DateTime                     @default(now())
  updatedAt                           DateTime                     @updatedAt
  grantedAt                           DateTime                     @default(now())
  failedLoginAttempts                 Int                          @default(0)
  lockUntil                           DateTime?                    @db.Timestamptz(6)
  resetPasswordToken                  String?
  resetPasswordExpires                DateTime?                    @db.Timestamptz(6)
  // Ngưỡng giá trị (VND) mà từ đó giao dịch WASTE/ADJUST phải chờ phê duyệt thay vì áp dụng ngay.
  inventoryApprovalThreshold          Decimal                      @default(500000) @db.Decimal(12, 2)
  accountPermissions                  AccountPermission[]
  activityLogs                        ActivityLog[]
  inventoryTransactionsCreated        InventoryTransaction[]       @relation("InventoryTransactionCreatedBy")
  inventoryAdjustmentRequestsMade     InventoryAdjustmentRequest[] @relation("AdjustmentRequestedBy")
  inventoryAdjustmentRequestsReviewed InventoryAdjustmentRequest[] @relation("AdjustmentReviewedBy")
  ingredientBatchesCreated            IngredientBatch[]
  inviteTokens                        InviteToken[]
  ordersCreated                       Order[]                      @relation("OrderCreatedBy")
  shifts                              Shift[]
  staffSessions                       StaffSession[]
  employees                           Employee[]

  @@index([email])
  @@map("accounts")
}

model DeviceSession {
  id               String    @id @default(cuid())
  deviceId         String    @map("device_id")
  tokenHash        String    @map("token_hash")
  refreshTokenHash String?   @map("refresh_token_hash")
  fingerprint      String?   @map("fingerprint")
  deviceName       String?   @map("device_name")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastUsedAt       DateTime? @map("last_used_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([deviceId])
  @@index([tokenHash])
  @@index([refreshTokenHash])
  @@index([fingerprint])
  @@index([expiresAt])
  @@map("device_sessions")
}

model TrustedDevice {
  id          String    @id @default(cuid())
  deviceId    String    @map("device_id")
  fingerprint String    @map("fingerprint")
  deviceName  String?   @map("device_name")
  isTrusted   Boolean   @default(true) @map("is_trusted")
  trustedAt   DateTime  @default(now()) @map("trusted_at")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([deviceId, fingerprint])
  @@index([deviceId])
  @@index([fingerprint])
  @@map("trusted_devices")
}

model StaffSession {
  id             String    @id @default(cuid())
  accountId      String    @map("account_id")
  deviceId       String    @map("device_id")
  shiftId        String?   @map("shift_id")
  loginAt        DateTime  @default(now()) @map("login_at")
  logoutAt       DateTime? @map("logout_at")
  lastActivityAt DateTime? @map("last_activity_at")
  account        Account   @relation(fields: [accountId], references: [id])
  shift          Shift?    @relation(fields: [shiftId], references: [id])

  @@index([accountId])
  @@index([deviceId])
  @@index([shiftId])
  @@index([loginAt])
  @@index([logoutAt])
  @@map("staff_sessions")
}

model MenuItem {
  id          String               @id @default(cuid())
  accountId   String
  name        String
  price       Decimal              @db.Decimal(10, 2)
  cost        Decimal              @db.Decimal(10, 2)
  description String?
  imageUrl    String?
  available   Boolean              @default(true)
  deletedAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  ingredients MenuItemIngredient[]
  modifiers   MenuItemModifier[]
  orderItems  OrderItem[]

  @@index([accountId])
  @@map("menu_items")
}

model MenuItemModifier {
  id                 String              @id @default(cuid())
  menuItemId         String
  name               String
  minSelect          Int                 @default(0)
  maxSelect          Int                 @default(1)
  price              Decimal             @default(0) @db.Decimal(10, 2)
  sortOrder          Int                 @default(0)
  menuItem           MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  orderItemModifiers OrderItemModifier[]

  @@index([menuItemId])
  @@map("menu_item_modifiers")
}

model MenuItemIngredient {
  id           String     @id @default(cuid())
  menuItemId   String
  ingredientId String
  amount       Decimal    @db.Decimal(10, 2)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
  @@map("menu_item_ingredients")
}

model Ingredient {
  id                    String                 @id @default(cuid())
  accountId             String
  name                  String
  unit                  IngredientUnit
  quantity              Decimal                @default(0) @db.Decimal(10, 2)
  warningQuantity       Decimal                @default(0) @db.Decimal(10, 2)
  maxQuantity           Decimal?               @db.Decimal(10, 2)
  price                 Decimal                @default(0) @db.Decimal(10, 2)
  supplier              String?
  sku                   String?
  location              String?
  barcode               String?
  available             Boolean                @default(true)
  lastUpdated           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  inventoryTransactions InventoryTransaction[]
  adjustmentRequests    InventoryAdjustmentRequest[]
  batches               IngredientBatch[]
  reservations          InventoryReservation[]
  menuItems             MenuItemIngredient[]
  orderItems            OrderItem[]
  stockAlerts           StockAlert[]
  stockAudits           StockAudit[]

  @@index([sku])
  @@index([barcode])
  @@index([name])
  @@index([accountId], map: "ingredients_branchId_idx")
  @@map("ingredients")
}

// Theo doi ton kho theo tung lo nhap + han su dung, de tieu thu theo FEFO
// (First Expired First Out) va canh bao truoc khi hang sap het han.
model IngredientBatch {
  id              String                @id @default(cuid())
  accountId       String
  ingredientId    String
  batchCode       String
  quantity        Decimal               @db.Decimal(10, 2)
  initialQuantity Decimal               @db.Decimal(10, 2)
  unitCost        Decimal?              @db.Decimal(12, 2)
  expiryDate      DateTime?
  receivedDate    DateTime              @default(now())
  status          IngredientBatchStatus @default(ACTIVE)
  note            String?
  createdBy       String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  ingredient      Ingredient            @relation(fields: [ingredientId], references: [id])
  creator         Account               @relation(fields: [createdBy], references: [id])

  @@index([ingredientId, status, expiryDate])
  @@index([accountId])
  @@map("ingredient_batches")
}

enum IngredientBatchStatus {
  ACTIVE
  DEPLETED
  EXPIRED
}

// Giu cho tam thoi tren Ingredient tu luc don hang duoc tao/sua toi luc thanh toan hoac huy,
// de ngan 2 don cung luc "thay" con hang trong khi thuc te chi du cho 1 don (rieng le, khong
// tinh vao Ingredient.quantity — chi dung de tinh "so luong kha dung" khi tao don moi).
model InventoryReservation {
  id           String   @id @default(cuid())
  accountId    String
  orderId      String
  ingredientId String
  quantity     Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([orderId])
  @@map("inventory_reservations")
}

model StockAlert {
  id           String     @id @default(cuid())
  ingredientId String
  branchId     String
  alertType    String     @default("LOW_STOCK")
  threshold    Decimal    @db.Decimal(10, 2)
  message      String?
  isResolved   Boolean    @default(false)
  resolvedAt   DateTime?
  resolvedBy   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@map("stock_alerts")
}

model StockAudit {
  id               String     @id @default(cuid())
  ingredientId     String
  branchId         String
  expectedQuantity Decimal    @db.Decimal(10, 2)
  actualQuantity   Decimal    @db.Decimal(10, 2)
  variance         Decimal    @db.Decimal(10, 2)
  notes            String?
  auditDate        DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  accountId        String
  ingredient       Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([branchId, auditDate])
  @@map("stock_audits")
}

model InventoryTransaction {
  id             String                   @id @default(cuid())
  accountId      String
  ingredientId   String
  createdBy      String
  type           InventoryTransactionType
  quantity       Decimal                  @db.Decimal(10, 2)
  beforeQuantity Decimal?                 @db.Decimal(10, 2)
  afterQuantity  Decimal?                 @db.Decimal(10, 2)
  note           String?
  referenceId    String?
  referenceType  String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  account        Account                  @relation("InventoryTransactionCreatedBy", fields: [createdBy], references: [id])
  ingredient     Ingredient               @relation(fields: [ingredientId], references: [id])

  @@index([ingredientId])
  @@index([accountId])
  @@index([createdBy])
  @@map("inventory_transactions")
}

// Yêu cầu điều chỉnh/hao hụt tồn kho vượt ngưỡng giá trị, cần quản lý duyệt trước khi
// thực sự trừ/điều chỉnh kho. Khác với InventoryTransaction (chỉ ghi giao dịch ĐÃ xảy ra),
// bảng này ghi những giao dịch ĐANG được đề xuất — chỉ khi APPROVED mới tạo InventoryTransaction thật.
model InventoryAdjustmentRequest {
  id              String                       @id @default(cuid())
  accountId       String
  ingredientId    String
  type            InventoryTransactionType
  quantity        Decimal                      @db.Decimal(10, 2)
  beforeQuantity  Decimal                       @db.Decimal(10, 2)
  afterQuantity   Decimal                       @db.Decimal(10, 2)
  estimatedValue  Decimal                       @db.Decimal(14, 2)
  note            String
  status          InventoryAdjustmentStatus     @default(PENDING)
  requestedBy     String
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  account         Account                       @relation("AdjustmentRequestedBy", fields: [requestedBy], references: [id])
  reviewer        Account?                      @relation("AdjustmentReviewedBy", fields: [reviewedBy], references: [id])
  ingredient      Ingredient                    @relation(fields: [ingredientId], references: [id])

  @@index([accountId, status])
  @@index([ingredientId])
  @@map("inventory_adjustment_requests")
}

model Shift {
  id             String         @id @default(cuid())
  branchId       String
  posDeviceId    String?
  accountId      String?
  startTime      DateTime       @default(now())
  endTime        DateTime?
  lastActive     DateTime?
  isOnline       Boolean        @default(true)
  ipAddress      String?
  userAgent      String?
  openingBalance Decimal        @default(0) @db.Decimal(12, 2)
  closingBalance Decimal?       @db.Decimal(12, 2)
  actualBalance  Decimal?       @db.Decimal(12, 2)
  cashSales      Decimal?       @default(0) @db.Decimal(12, 2)
  cardSales      Decimal?       @default(0) @db.Decimal(12, 2)
  otherSales     Decimal?       @default(0) @db.Decimal(12, 2)
  totalOrders    Int?           @default(0)
  note           String?
  status         ShiftStatus    @default(OPEN)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  orders         Order[]
  account        Account?       @relation(fields: [accountId], references: [id])
  staffSessions  StaffSession[]

  @@index([branchId, accountId])
  @@index([isOnline], map: "shifts_is_online_idx")
  @@index([lastActive], map: "shifts_last_active_idx")
  @@map("shifts")
}

model Order {
  id                     String            @id @default(cuid())
  accountId              String
  posDeviceId            String?
  createdBy              String
  createdByUserId        String?
  shiftId                String?
  customerId             String?
  orderNumber            String            @unique
  source                 String?           @default("POS")
  tableNumber            String?
  tableId                String?           @map("table_id")
  status                 OrderStatus
  kitchenStatus          KitchenStatus     @default(PENDING)
  paymentMethod          PaymentMethod?
  paymentStatus          PaymentStatus     @default(UNPAID)
  orderType              OrderType
  subtotal               Decimal           @default(0) @db.Decimal(12, 2)
  tax                    Decimal           @default(0) @db.Decimal(12, 2)
  taxRate                Decimal?          @db.Decimal(5, 2)
  serviceCharge          Decimal           @default(0) @db.Decimal(12, 2)
  discount               Decimal           @default(0) @db.Decimal(12, 2)
  rounding               Decimal           @default(0) @db.Decimal(12, 2)
  total                  Decimal           @default(0) @db.Decimal(12, 2)
  cost                   Decimal           @default(0) @db.Decimal(12, 2)
  profit                 Decimal           @default(0) @db.Decimal(12, 2)
  note                   String?
  guestCount             Int?              @default(1)
  inventoryDeducted      Boolean           @default(false)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  completedAt            DateTime?
  deletedAt              DateTime?
  sessionId              String?           @unique @map("session_id")
  tableName              String?
  tableCode              String?
  tableType              String?
  sessionStartTime       DateTime?
  playingDurationMinutes Int?              @default(0)
  hourlyRate             Decimal?          @default(0) @db.Decimal(12, 2)
  playingCost            Decimal?          @default(0) @db.Decimal(12, 2)
  foodDrinkTotal         Decimal?          @default(0) @db.Decimal(12, 2)
  mergedTableIds         Json?
  kots                   Kot[]
  items                  OrderItem[]
  account                Account           @relation("OrderCreatedBy", fields: [createdBy], references: [id])
  customer               Customer?         @relation(fields: [customerId], references: [id])
  session                PlaySession?      @relation("SessionOrder", fields: [sessionId], references: [id])
  shift                  Shift?            @relation(fields: [shiftId], references: [id])
  table                  Table?            @relation("TableOrders", fields: [tableId], references: [id])
  payments               Payment[]
  redeemedVouchers       RedeemedVoucher[]
  inventoryReservations  InventoryReservation[]

  @@index([shiftId])
  @@index([orderNumber])
  @@index([tableNumber])
  @@index([tableId])
  @@index([accountId, createdAt], map: "orders_branchId_createdAt_idx")
  @@index([accountId, paymentStatus], map: "orders_branchId_paymentStatus_idx")
  @@index([accountId, status], map: "orders_branchId_status_idx")
  @@index([createdByUserId], map: "orders_created_by_user_id_idx")
  @@map("orders")
}

model OrderItem {
  id          String              @id @default(cuid())
  orderId     String
  menuItemId  String?
  kotId       String?
  name        String
  price       Decimal             @db.Decimal(12, 2)
  cost        Decimal             @default(0) @db.Decimal(12, 2)
  quantity    Int
  discount    Decimal             @default(0) @db.Decimal(12, 2)
  total       Decimal             @default(0) @db.Decimal(12, 2)
  note        String?
  inventoryId String?             @map("inventory_id")
  // Snapshot cong thuc (danh sach { ingredientId, ingredientName, unit, amount }) tai thoi diem
  // tao don. Cho phep null (don cu truoc khi co tinh nang nay) -> fallback ve query cong thuc
  // hien tai luc thanh toan, giu nguyen hanh vi cu.
  recipeSnapshot Json?
  modifiers   OrderItemModifier[]
  inventory   Ingredient?         @relation(fields: [inventoryId], references: [id])
  kot         Kot?                @relation(fields: [kotId], references: [id])
  menuItem    MenuItem?           @relation(fields: [menuItemId], references: [id])
  order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, menuItemId])
  @@index([orderId])
  @@index([menuItemId])
  @@index([inventoryId])
  @@index([kotId])
  @@map("order_items")
}

model OrderItemModifier {
  id          String            @id @default(cuid())
  orderItemId String
  modifierId  String?
  name        String
  price       Decimal           @default(0) @db.Decimal(10, 2)
  quantity    Int               @default(1)
  modifier    MenuItemModifier? @relation(fields: [modifierId], references: [id])
  orderItem   OrderItem         @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

model Kot {
  id          String        @id @default(cuid())
  orderId     String
  branchId    String
  kotNumber   String        @unique
  status      KitchenStatus @default(PENDING)
  priority    Int           @default(0)
  note        String?
  preparedBy  String?
  preparedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items       OrderItem[]

  @@index([orderId])
  @@index([status])
  @@index([branchId, status])
  @@map("kots")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  status        PaymentStatus
  reference     String?
  transactionId String?
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("payments")
}

model Customer {
  id               String            @id @default(cuid())
  branchId         String
  name             String
  phone            String?
  email            String?
  birthDate        DateTime?
  totalSpent       Decimal           @default(0) @db.Decimal(12, 2)
  visitCount       Int               @default(0)
  lastVisit        DateTime?
  tier             LoyaltyTier       @default(BRONZE)
  points           Int               @default(0)
  note             String?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  loyaltyPoints    LoyaltyPoint[]
  orders           Order[]
  redeemedVouchers RedeemedVoucher[]

  @@unique([branchId, phone])
  @@index([points])
  @@index([branchId, tier])
  @@map("customers")
}

model LoyaltyPoint {
  id         String    @id @default(cuid())
  customerId String
  branchId   String
  points     Int
  type       String    @default("EARN")
  reference  String?
  note       String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
  @@index([branchId, createdAt])
  @@map("loyalty_points")
}

model Voucher {
  id               String            @id @default(cuid())
  branchId         String
  code             String            @unique
  type             VoucherType
  name             String
  description      String?
  discountValue    Decimal           @db.Decimal(12, 2)
  maxDiscount      Decimal?          @db.Decimal(12, 2)
  minOrderValue    Decimal?          @db.Decimal(12, 2)
  usageLimit       Int?              @default(0)
  usedCount        Int               @default(0)
  pointsCost       Int               @default(0)
  startDate        DateTime
  endDate          DateTime
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  redeemedVouchers RedeemedVoucher[]

  @@index([code])
  @@index([startDate, endDate])
  @@index([branchId, isActive])
  @@map("vouchers")
}

model RedeemedVoucher {
  id         String   @id @default(cuid())
  voucherId  String
  customerId String
  orderId    String?
  discount   Decimal  @db.Decimal(12, 2)
  redeemedAt DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])
  order      Order?   @relation(fields: [orderId], references: [id])
  voucher    Voucher  @relation(fields: [voucherId], references: [id])

  @@index([voucherId])
  @@index([customerId])
  @@index([orderId])
  @@map("redeemed_vouchers")
}

model InviteToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  accountId String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@map("invite_tokens")
}

model ActivityLog {
  id          String   @id @default(cuid())
  accountId   String?
  employeeId  String?
  posDeviceId String?
  action      String
  module      String
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  account     Account? @relation(fields: [accountId], references: [id])
  employee    Employee? @relation(fields: [employeeId], references: [id])

  @@index([accountId, createdAt])
  @@index([module, action])
  @@index([employeeId, createdAt])
  @@map("activity_logs")
}

model BranchInvitation {
  id         String           @id @default(cuid())
  email      String
  packageId  String
  tokenHash  String           @unique
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdBy  String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  package    SubscriptionPlan @relation(fields: [packageId], references: [id])

  @@index([email])
  @@index([status])
  @@index([email, status])
  @@map("branch_invitations")
}

model BranchBankAccount {
  id             String   @id @default(cuid())
  branchId       String
  bankCode       String
  bankName       String
  accountNumber  String
  accountHolder  String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([branchId])
  @@map("branch_bank_accounts")
}

