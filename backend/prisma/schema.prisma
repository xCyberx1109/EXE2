// Prisma schema - Quản lý cửa hàng F&B
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  PREPARING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  QR
}

enum InventoryTransactionType {
  IN
  OUT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String   @map("full_name")
  role      Role     @default(STAFF)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders                Order[]
  inventoryTransactions InventoryTransaction[]

  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?    @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  menuItems   MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  categoryId  String   @map("category_id")
  price       Decimal  @db.Decimal(12, 2)
  cost        Decimal  @db.Decimal(12, 2)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  available   Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category    Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems  OrderItem[]
  ingredients MenuItemIngredient[]

  @@index([categoryId])
  @@index([available])
  @@map("menu_items")
}

model MenuItemIngredient {
  id           String  @id @default(uuid())
  menuItemId   String  @map("menu_item_id")
  ingredientId String  @map("ingredient_id")
  amount       Decimal @db.Decimal(10, 3)

  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])
  @@map("menu_item_ingredients")
}

model Ingredient {
  id          String   @id @default(uuid())
  name        String   @unique
  unit        String
  quantity    Decimal  @db.Decimal(12, 3)
  minQuantity Decimal  @map("min_quantity") @db.Decimal(12, 3)
  price       Decimal  @db.Decimal(12, 2)
  supplier    String
  lastUpdated DateTime @default(now()) @map("last_updated")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  menuItems    MenuItemIngredient[]
  transactions InventoryTransaction[]

  @@map("ingredients")
}

model InventoryTransaction {
  id           String                   @id @default(uuid())
  ingredientId String                   @map("ingredient_id")
  type         InventoryTransactionType
  quantity     Decimal                  @db.Decimal(12, 3)
  note         String?                  @db.Text
  userId       String?                  @map("user_id")
  createdAt    DateTime                 @default(now()) @map("created_at")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ingredientId])
  @@index([createdAt])
  @@map("inventory_transactions")
}

model Order {
  id            String         @id @default(uuid())
  orderNumber   String         @unique @map("order_number")
  tableNumber   Int?           @map("table_number")
  status        OrderStatus    @default(PENDING)
  paymentMethod PaymentMethod? @map("payment_method")
  subtotal      Decimal        @default(0) @db.Decimal(12, 2)
  tax           Decimal        @default(0) @db.Decimal(12, 2)
  total         Decimal        @default(0) @db.Decimal(12, 2)
  cost          Decimal        @default(0) @db.Decimal(12, 2)
  profit        Decimal        @default(0) @db.Decimal(12, 2)
  userId        String?        @map("user_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  completedAt   DateTime?      @map("completed_at")

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([tableNumber])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String  @map("order_id")
  menuItemId String? @map("menu_item_id")
  name       String
  price      Decimal @db.Decimal(12, 2)
  cost       Decimal @default(0) @db.Decimal(12, 2)
  quantity   Int

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model RevenueReport {
  id         String   @id @default(uuid())
  reportDate DateTime @unique @map("report_date") @db.Date
  orderCount Int      @default(0) @map("order_count")
  revenue    Decimal  @default(0) @db.Decimal(14, 2)
  cost       Decimal  @default(0) @db.Decimal(14, 2)
  profit     Decimal  @default(0) @db.Decimal(14, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("revenue_reports")
}
