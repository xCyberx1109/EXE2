  createdAt    DateTime     @default(now())

  employee   Employee     @relation(fields: [employeeId], references: [id])
  posMachine pos_machines @relation(fields: [posMachineId], references: [id])

  @@index([employeeId])
  @@index([posMachineId])
  @@index([isActive])
  @@map("pos_machine_sessions")
}

model EmployeePosMachine {
  id           String       @id @default(cuid())
  employeeId   String
