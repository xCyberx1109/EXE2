generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========================================
// ENUMS
// ========================================

enum Plan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  COOK
}

enum PosDeviceType {
  CASHIER
  TABLET
  KIOSK
}

enum PosStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

enum InventoryTransactionType {
  IMPORT
  EXPORT
  ADJUST
  RETURN
  WASTE
}

enum OrderStatus {
  PENDING
  PREPARING
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANKING
  E_WALLET
  OTHER
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum OrderType {
  DINE_IN
  TAKE_AWAY
  DELIVERY
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum IngredientUnit {
  KG
  G
  LITER
  ML
  PIECE
}

// ========================================
// MODELS
// ========================================

model Branch {
  id                 String             @id @default(cuid())
  name               String
  address            String
  phone              String
  email              String?
  logoUrl            String?
  plan               Plan
  subscriptionStatus SubscriptionStatus
  subscriptionStart  DateTime
  subscriptionEnd    DateTime
  features           Json?
  active             Boolean            @default(true)

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  accounts              Account[]
  posDevices            PosDevice[]
  menuItems             MenuItem[]
  ingredients           Ingredient[]
  inventoryTransactions InventoryTransaction[]
  orders                Order[]
  shifts                Shift[]
  categories            Category[]

  activityLogs          ActivityLog[]

  @@map("branches")
}

model Account {
  id                 String   @id @default(cuid())
  branchId           String

  email              String   @unique
  password           String

  pinCode            String?

  fullName           String
  phone              String?

  role               Role

  mustChangePassword Boolean  @default(true)

  active             Boolean  @default(true)

  deletedAt          DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  branch                Branch                 @relation(fields: [branchId], references: [id])

  inventoryTransactions InventoryTransaction[]
  orders                Order[]
  shifts                Shift[]
  activityLogs          ActivityLog[]

  @@unique([branchId, pinCode])

  @@index([branchId, role])
  @@index([active])

  @@map("accounts")
}

model PosDevice {
  id           String        @id @default(cuid())
  branchId     String

  name         String

  deviceCode   String        @unique

  devicePin    String?       @unique
  deviceToken  String?       @unique

  type         PosDeviceType

  status       PosStatus     @default(OFFLINE)

  active       Boolean       @default(true)

  lastActive   DateTime?

  currentVersion String?

  deletedAt    DateTime?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  orders Order[]
  shifts Shift[]

  @@index([branchId])
  @@index([status])
  @@index([active])

  @@map("pos_devices")
}

model Category {
  id          String    @id @default(cuid())

  branchId    String

  name        String
  slug        String

  description String?   @db.Text

  active      Boolean   @default(true)

  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch    Branch     @relation(fields: [branchId], references: [id])

  menuItems MenuItem[]

  @@unique([branchId, slug])

  @@index([branchId])

  @@map("categories")
}

model MenuItem {
  id          String    @id @default(cuid())

  branchId    String
  categoryId  String

  name        String

  price       Decimal   @db.Decimal(10, 2)
  cost        Decimal   @db.Decimal(10, 2)

  description String?   @db.Text

  imageUrl    String?

  available   Boolean   @default(true)

  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch      Branch               @relation(fields: [branchId], references: [id])

  category    Category             @relation(fields: [categoryId], references: [id])

  ingredients MenuItemIngredient[]
  orderItems  OrderItem[]

  @@index([branchId, categoryId])

  @@map("menu_items")
}

model MenuItemIngredient {
  id           String  @id @default(cuid())

  menuItemId   String
  ingredientId String

  amount       Decimal @db.Decimal(10, 2)

  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@map("menu_item_ingredients")
}

model Ingredient {
  id          String          @id @default(cuid())

  branchId    String

  name        String

  unit        IngredientUnit

  quantity    Decimal         @db.Decimal(10, 2)
  minQuantity Decimal         @db.Decimal(10, 2)

  price       Decimal         @db.Decimal(10, 2)

  supplier    String?

  available   Boolean         @default(true)

  deletedAt   DateTime?

  lastUpdated DateTime?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  branch                Branch                 @relation(fields: [branchId], references: [id])

  menuItems             MenuItemIngredient[]

  inventoryTransactions InventoryTransaction[]

  @@index([branchId])

  @@map("ingredients")
}

model InventoryTransaction {
  id           String                   @id @default(cuid())

  branchId     String
  ingredientId String

  createdBy    String

  type         InventoryTransactionType

  quantity     Decimal                  @db.Decimal(10, 2)

  beforeQuantity Decimal?               @db.Decimal(10, 2)
  afterQuantity  Decimal?               @db.Decimal(10, 2)

  note         String?                  @db.Text

  referenceId  String?

  createdAt    DateTime                 @default(now())

  branch     Branch     @relation(fields: [branchId], references: [id])

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  account    Account    @relation(fields: [createdBy], references: [id])

  @@index([branchId, ingredientId])

  @@map("inventory_transactions")
}

model Shift {
  id             String      @id @default(cuid())

  branchId       String
  posDeviceId    String
  accountId      String?

  startTime      DateTime    @default(now())
  endTime        DateTime?

  lastActive     DateTime?

  isOnline       Boolean     @default(true)

  ipAddress      String?
  userAgent      String?

  openingBalance Decimal     @db.Decimal(10, 2)

  closingBalance Decimal?    @db.Decimal(10, 2)

  actualBalance  Decimal?    @db.Decimal(10, 2)

  note           String?     @db.Text

  status         ShiftStatus @default(OPEN)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  branch    Branch     @relation(fields: [branchId], references: [id])

  posDevice PosDevice  @relation(fields: [posDeviceId], references: [id])

  account   Account?   @relation(fields: [accountId], references: [id])

  orders    Order[]

  @@index([branchId, accountId])

  @@index([status, isOnline])

  @@map("shifts")
}

model Order {
  id            String        @id @default(cuid())

  branchId      String

  posDeviceId   String

  createdBy     String

  shiftId       String?

  orderNumber   String        @unique

  source        String?

  tableNumber   String?

  status        OrderStatus

  paymentMethod PaymentMethod?

  paymentStatus PaymentStatus @default(UNPAID)

  orderType     OrderType

  subtotal      Decimal       @db.Decimal(10, 2)

  tax           Decimal       @db.Decimal(10, 2)

  serviceCharge Decimal       @default(0) @db.Decimal(10, 2)

  discount      Decimal       @default(0) @db.Decimal(10, 2)

  total         Decimal       @db.Decimal(10, 2)

  cost          Decimal       @db.Decimal(10, 2)

  profit        Decimal       @db.Decimal(10, 2)

  note          String?       @db.Text

  createdAt     DateTime      @default(now())

  completedAt   DateTime?

  branch     Branch      @relation(fields: [branchId], references: [id])

  posDevice  PosDevice   @relation(fields: [posDeviceId], references: [id])

  account    Account     @relation(fields: [createdBy], references: [id])

  shift      Shift?      @relation(fields: [shiftId], references: [id])

  orderItems OrderItem[]

  payments   Payment[]

  @@index([branchId, createdAt])

  @@index([shiftId])

  @@index([branchId, status])

  @@index([branchId, paymentStatus])

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())

  orderId    String
  menuItemId String

  name       String

  price      Decimal @db.Decimal(10, 2)

  cost       Decimal @db.Decimal(10, 2)

  quantity   Int

  discount   Decimal @default(0) @db.Decimal(10, 2)

  total      Decimal @db.Decimal(10, 2)

  note       String? @db.Text

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])

  @@map("order_items")
}

model Payment {
  id            String        @id @default(cuid())

  orderId       String

  amount        Decimal       @db.Decimal(10, 2)

  method        PaymentMethod

  status        PaymentStatus

  transactionId String?

  note          String?       @db.Text

  createdAt     DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])

  @@index([createdAt])

  @@map("payments")
}

model ActivityLog {
  id          String    @id @default(cuid())

  branchId    String

  accountId   String?

  posDeviceId String?

  action      String

  module      String

  details     Json?

  ipAddress   String?

  createdAt   DateTime  @default(now())

  branch  Branch    @relation(fields: [branchId], references: [id])

  account Account?  @relation(fields: [accountId], references: [id])

  @@index([branchId, createdAt])

  @@index([accountId, createdAt])

  @@map("activity_logs")
}