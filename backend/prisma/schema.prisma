  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  posMachine pos_machines @relation(fields: [posMachineId], references: [id], onDelete: Cascade)

  @@unique([employeeId, posMachineId])
  @@index([employeeId])
  @@index([posMachineId])
  @@map("employee_pos_machines")
}

