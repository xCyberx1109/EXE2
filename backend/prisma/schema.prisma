// =========================
// PRISMA SCHEMA - F&B MANAGEMENT SYSTEM
// =========================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =========================
// ENUMS
// =========================

enum Role {
  ADMIN
  BRANCH
  STAFF
}

enum OrderStatus {
  PENDING
  PREPARING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  QR
}

enum InventoryTransactionType {
  IN
  OUT
}

enum PosDeviceType {
  CASHIER
  KIOSK
  MOBILE
  KITCHEN
}

// =========================
// BRANCHES
// =========================

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  posDevices  PosDevice[]
  ingredients Ingredient[]
  orders      Order[]

  @@map("branches")
}

// =========================
// USERS
// =========================

model User {
  id        String   @id @default(uuid())
  branchId  String?  @map("branch_id")

  email     String   @unique
  password  String

  fullName  String   @map("full_name")

  role      Role     @default(BRANCH)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  orders                Order[]
  inventoryTransactions InventoryTransaction[]
  shifts                Shift[]

  @@index([branchId])

  @@map("users")
}

// =========================
// POS DEVICES
// =========================

model PosDevice {
  id         String        @id @default(uuid())

  branchId   String        @map("branch_id")

  name       String

  deviceCode String        @unique @map("device_code")

  type       PosDeviceType @default(CASHIER)

  active     Boolean       @default(true)

  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  orders Order[]
  shifts Shift[]

  @@index([branchId])

  @@map("pos_devices")
}

// =========================
// SHIFTS
// =========================

model Shift {
  id          String    @id @default(uuid())

  userId      String?   @map("user_id")

  posDeviceId String    @map("pos_device_id")

  openedAt    DateTime  @default(now()) @map("opened_at")

  closedAt    DateTime? @map("closed_at")

  openingCash Decimal   @default(0) @map("opening_cash") @db.Decimal(12, 2)

  closingCash Decimal?  @map("closing_cash") @db.Decimal(12, 2)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  posDevice PosDevice @relation(fields: [posDeviceId], references: [id], onDelete: Cascade)

  @@index([posDeviceId])

  @@map("shifts")
}

// =========================
// CATEGORIES
// =========================

model Category {
  id          String     @id @default(uuid())

  name        String     @unique

  slug        String     @unique

  description String?    @db.Text

  createdAt   DateTime   @default(now()) @map("created_at")

  updatedAt   DateTime   @updatedAt @map("updated_at")

  deletedAt   DateTime?  @map("deleted_at")

  menuItems   MenuItem[]

  @@map("categories")
}

// =========================
// MENU ITEMS
// =========================

model MenuItem {
  id          String   @id @default(uuid())

  name        String

  categoryId  String   @map("category_id")

  price       Decimal  @db.Decimal(12, 2)

  cost        Decimal  @db.Decimal(12, 2)

  description String?  @db.Text

  imageUrl    String?  @map("image_url") @db.VarChar(500)

  available   Boolean  @default(true)

  createdAt   DateTime @default(now()) @map("created_at")

  updatedAt   DateTime @updatedAt @map("updated_at")

  deletedAt   DateTime? @map("deleted_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  orderItems  OrderItem[]

  ingredients MenuItemIngredient[]

  @@index([categoryId])

  @@index([available])

  @@map("menu_items")
}

// =========================
// MENU ITEM INGREDIENTS
// =========================

model MenuItemIngredient {
  id           String  @id @default(uuid())

  menuItemId   String  @map("menu_item_id")

  ingredientId String  @map("ingredient_id")

  amount       Decimal @db.Decimal(10, 3)

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])

  @@map("menu_item_ingredients")
}

// =========================
// INGREDIENTS
// =========================

model Ingredient {
  id          String   @id @default(uuid())

  branchId    String   @map("branch_id")

  name        String

  unit        String

  quantity    Decimal  @db.Decimal(12, 3)

  minQuantity Decimal  @map("min_quantity") @db.Decimal(12, 3)

  price       Decimal  @db.Decimal(12, 2)

  supplier    String

  lastUpdated DateTime @default(now()) @map("last_updated")

  createdAt   DateTime @default(now()) @map("created_at")

  updatedAt   DateTime @updatedAt @map("updated_at")

  deletedAt   DateTime? @map("deleted_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  menuItems MenuItemIngredient[]

  transactions InventoryTransaction[]

  @@index([branchId])

  @@unique([branchId, name])

  @@map("ingredients")
}

// =========================
// INVENTORY TRANSACTIONS
// =========================

model InventoryTransaction {
  id           String                   @id @default(uuid())

  ingredientId String                   @map("ingredient_id")

  type         InventoryTransactionType

  quantity     Decimal                  @db.Decimal(12, 3)

  note         String?                  @db.Text

  userId       String?                  @map("user_id")

  createdAt    DateTime                 @default(now()) @map("created_at")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ingredientId])

  @@index([createdAt])

  @@map("inventory_transactions")
}

// =========================
// ORDERS
// =========================

model Order {
  id            String         @id @default(uuid())

  branchId      String         @map("branch_id")

  posDeviceId   String?        @map("pos_device_id")

  orderNumber   String         @unique @map("order_number")

  tableNumber   Int?           @map("table_number")

  status        OrderStatus    @default(PENDING)

  paymentMethod PaymentMethod? @map("payment_method")

  subtotal      Decimal        @default(0) @db.Decimal(12, 2)

  tax           Decimal        @default(0) @db.Decimal(12, 2)

  total         Decimal        @default(0) @db.Decimal(12, 2)

  cost          Decimal        @default(0) @db.Decimal(12, 2)

  profit        Decimal        @default(0) @db.Decimal(12, 2)

  userId        String?        @map("user_id")

  createdAt     DateTime       @default(now()) @map("created_at")

  completedAt   DateTime?      @map("completed_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  posDevice PosDevice? @relation(fields: [posDeviceId], references: [id], onDelete: SetNull)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  items OrderItem[]

  @@index([branchId])

  @@index([posDeviceId])

  @@index([tableNumber])

  @@index([status])

  @@index([createdAt])

  @@map("orders")
}

// =========================
// ORDER ITEMS
// =========================

model OrderItem {
  id         String  @id @default(uuid())

  orderId    String  @map("order_id")

  menuItemId String? @map("menu_item_id")

  name       String

  price      Decimal @db.Decimal(12, 2)

  cost       Decimal @default(0) @db.Decimal(12, 2)

  quantity   Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItem MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])

  @@index([menuItemId])

  @@map("order_items")
}

// =========================
// REVENUE REPORTS
// =========================

model RevenueReport {
  id         String   @id @default(uuid())

  reportDate DateTime @unique @map("report_date") @db.Date

  orderCount Int      @default(0) @map("order_count")

  revenue    Decimal  @default(0) @db.Decimal(14, 2)

  cost       Decimal  @default(0) @db.Decimal(14, 2)

  profit     Decimal  @default(0) @db.Decimal(14, 2)

  createdAt  DateTime @default(now()) @map("created_at")

  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("revenue_reports")
}