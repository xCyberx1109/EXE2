generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Plan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  STAFF
}

enum PosDeviceType {
  CASHIER
  TABLET
  KIOSK
}

enum InventoryTransactionType {
  IMPORT
  EXPORT
  ADJUST
}

enum OrderStatus {
  PENDING
  PREPARING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANKING
  E_WALLET
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum OrderType {
  DINE_IN
  TAKE_AWAY
  DELIVERY
}

model Branch {
  id                   String   @id @default(cuid())

  name                 String
  address              String
  phone                String

  plan                 Plan
  subscriptionStatus   SubscriptionStatus

  subscriptionStart    DateTime
  subscriptionEnd      DateTime

  features             Json?

  active               Boolean  @default(true)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  accounts             Account[]
  posDevices           PosDevice[]
  menuItems            MenuItem[]
  ingredients          Ingredient[]
  inventoryTransactions InventoryTransaction[]
  orders               Order[]

  @@map("branches")
}

model Account {
  id              String   @id @default(cuid())

  branchId        String

  email           String   @unique
  password        String

  fullName        String

  role            Role

  isSuperAdmin    Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch          Branch @relation(fields: [branchId], references: [id])

  inventoryTransactions InventoryTransaction[]
  orders                Order[]

  @@map("accounts")
}

model PosDevice {
  id            String   @id @default(cuid())

  branchId      String

  name          String

  deviceCode    String   @unique

  type          PosDeviceType

  active        Boolean  @default(true)

  lastActive    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch        Branch @relation(fields: [branchId], references: [id])

  orders        Order[]

  @@map("pos_devices")
}

model Category {
  id            String   @id @default(cuid())

  name          String   @unique
  slug          String   @unique

  description   String?  @db.Text

  deletedAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  menuItems     MenuItem[]

  @@map("categories")
}

model MenuItem {
  id            String   @id @default(cuid())

  branchId      String
  categoryId    String

  name          String

  price         Decimal  @db.Decimal(10, 2)
  cost          Decimal  @db.Decimal(10, 2)

  description   String?  @db.Text

  imageUrl      String?

  available     Boolean  @default(true)

  deletedAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch        Branch   @relation(fields: [branchId], references: [id])
  category      Category @relation(fields: [categoryId], references: [id])

  ingredients   MenuItemIngredient[]
  orderItems    OrderItem[]

  @@map("menu_items")
}

model MenuItemIngredient {
  id            String   @id @default(cuid())

  menuItemId    String
  ingredientId  String

  amount        Decimal  @db.Decimal(10, 2)

  menuItem      MenuItem   @relation(fields: [menuItemId], references: [id])
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])

  @@map("menu_item_ingredients")
}

model Ingredient {
  id            String   @id @default(cuid())

  branchId      String

  name          String

  unit          String

  quantity      Decimal  @db.Decimal(10, 2)
  minQuantity   Decimal  @db.Decimal(10, 2)

  price         Decimal  @db.Decimal(10, 2)

  supplier      String?

  available     Boolean  @default(true)

  deletedAt     DateTime?

  lastUpdated   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch        Branch @relation(fields: [branchId], references: [id])

  menuItems     MenuItemIngredient[]
  inventoryTransactions InventoryTransaction[]

  @@map("ingredients")
}

model InventoryTransaction {
  id            String   @id @default(cuid())

  branchId      String
  ingredientId  String

  createdBy     String

  type          InventoryTransactionType

  quantity      Decimal  @db.Decimal(10, 2)

  note          String?  @db.Text

  createdAt     DateTime @default(now())

  branch        Branch @relation(fields: [branchId], references: [id])

  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])

  account       Account @relation(fields: [createdBy], references: [id])

  @@map("inventory_transactions")
}

model Order {
  id              String   @id @default(cuid())

  branchId        String
  posDeviceId     String

  createdBy       String

  orderNumber     String   @unique

  tableNumber     Int?

  status          OrderStatus

  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus

  orderType       OrderType

  subtotal        Decimal  @db.Decimal(10, 2)
  tax             Decimal  @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)

  cost            Decimal  @db.Decimal(10, 2)
  profit          Decimal  @db.Decimal(10, 2)

  createdAt       DateTime @default(now())
  completedAt     DateTime?

  branch          Branch @relation(fields: [branchId], references: [id])

  posDevice       PosDevice @relation(fields: [posDeviceId], references: [id])

  account         Account @relation(fields: [createdBy], references: [id])

  orderItems      OrderItem[]

  @@map("orders")
}

model OrderItem {
  id            String   @id @default(cuid())

  orderId       String
  menuItemId    String

  name          String

  price         Decimal  @db.Decimal(10, 2)
  cost          Decimal  @db.Decimal(10, 2)

  quantity      Int

  order         Order @relation(fields: [orderId], references: [id])

  menuItem      MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}