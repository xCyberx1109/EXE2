generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Feature {
  id                       String                    @id @default(cuid())
  code                     String                    @unique
  name                     String
  description              String?
  module                   String
  isCore                   Boolean                   @default(false)
  sortOrder                Int                       @default(0)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  deletedAt                DateTime?
  deviceOverrides          DeviceFeatureOverride[]
  dependedBy               FeatureDependency[]       @relation("FeatureDependedBy")
  featureDependencies      FeatureDependency[]       @relation("FeatureDependencies")
  featurePermissions       FeaturePermission[]
  subscriptionPlanFeatures SubscriptionPlanFeature[]

  @@index([module])
  @@index([isCore])
  @@map("features")
}

model FeatureDependency {
  id          String  @id @default(cuid())
  featureId   String
  dependsOnId String
  dependsOn   Feature @relation("FeatureDependedBy", fields: [dependsOnId], references: [id], onDelete: Cascade)
  feature     Feature @relation("FeatureDependencies", fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([featureId, dependsOnId])
  @@map("feature_dependencies")
}

model FeaturePermission {
  id           String     @id @default(cuid())
  featureId    String
  permissionId String
  feature      Feature    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([featureId, permissionId])
  @@map("feature_permissions")
}

model Permission {
  id                    String                 @id @default(cuid())
  code                  String                 @unique
  name                  String
  description           String?
  module                String
  isSystem              Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  accountPermissions    AccountPermission[]
  deviceTypePermissions DeviceTypePermission[]
  featurePermissions    FeaturePermission[]

  @@index([module])
  @@map("permissions")
}

model DeviceTypePermission {
  id           String        @id @default(cuid())
  deviceType   PosDeviceType
  permissionId String
  isRequired   Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  permission   Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([deviceType, permissionId])
  @@index([deviceType])
  @@map("device_type_permissions")
}

model DeviceFeatureOverride {
  id        String    @id @default(cuid())
  deviceId  String
  featureId String
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  device    PosDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  feature   Feature   @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([deviceId, featureId])
  @@index([deviceId])
  @@map("device_feature_overrides")
}

model AccountPermission {
  id           String     @id @default(cuid())
  accountId    String
  permissionId String
  allowed      Boolean    @default(true)
  grantedBy    String?
  createdAt    DateTime   @default(now())
  expiresAt    DateTime?
  account      Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([accountId, permissionId])
  @@index([accountId])
  @@index([expiresAt])
  @@map("account_permissions")
}

model SubscriptionPlan {
  id              String                      @id @default(cuid())
  code            String                      @unique
  name            String
  description     String?
  price           Decimal                     @db.Decimal(12, 2)
  billingInterval SubscriptionBillingInterval @default(MONTHLY)
  isActive        Boolean                     @default(true)
  planFeatures    SubscriptionPlanFeature[]
  subscriptions   Subscription[]

  @@index([isActive])
  @@index([billingInterval])
  @@map("subscription_plans")
}

model SubscriptionPlanFeature {
  id                 String           @id @default(cuid())
  subscriptionPlanId String
  featureId          String
  feature            Feature          @relation(fields: [featureId], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Cascade)

  @@unique([subscriptionPlanId, featureId])
  @@map("subscription_plan_features")
}

model Subscription {
  id          String             @id @default(cuid())
  branchId    String
  planId      String
  status      SubscriptionStatus @default(TRIAL)
  startDate   DateTime
  endDate     DateTime
  trialEndsAt DateTime?
  cancelledAt DateTime?
  autoRenew   Boolean            @default(true)
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  invoices    BillingInvoice[]
  plan        SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([endDate])
  @@index([trialEndsAt])
  @@index([branchId, status])
  @@map("subscriptions")
}

model BillingInvoice {
  id             String       @id @default(cuid())
  subscriptionId String
  invoiceNumber  String       @unique
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @default("VND")
  status         String       @default("PENDING")
  paidAt         DateTime?
  dueDate        DateTime
  paidAmount     Decimal?     @db.Decimal(12, 2)
  paymentMethod  String?
  notes          String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@map("billing_invoices")
}

model Table {
  id        String          @id @default(cuid())
  accountId String
  tableCode String
  tableName String?
  capacity  Int
  tableType TableType       @default(POOL)
  posX      Float           @default(0)
  posY      Float           @default(0)
  hourlyRate Decimal        @default(0) @db.Decimal(12, 2)
  status    TableStatus     @default(AVAILABLE)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  orders    Order[]         @relation("TableOrders")
  sessions  PlaySession[]
  reservations Reservation[]

  @@unique([accountId, tableCode])
  @@index([accountId])
  @@map("tables")
}

model PlaySession {
  id              String           @id @default(cuid())
  tableId         String
  startTime       DateTime
  expectedEndTime DateTime
  endTime         DateTime?
  durationMinutes Int
  tableFee        Decimal          @default(0) @db.Decimal(12, 2)
  status          PlaySessionStatus @default(PLAYING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  table           Table            @relation(fields: [tableId], references: [id])
  order           Order?           @relation("SessionOrder")

  @@index([tableId])
  @@index([status])
  @@index([tableId, status])
  @@map("play_sessions")
}

model Reservation {
  id               String             @id @default(cuid())
  tableId          String
  branchId         String
  customerName     String
  phone            String?
  reservationTime  DateTime
  durationMinutes  Int                @default(60)
  note             String?
  status           ReservationStatus  @default(PENDING)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  table            Table              @relation(fields: [tableId], references: [id])

  @@index([tableId])
  @@index([status])
  @@index([reservationTime])
  @@index([branchId, status])
  @@map("reservations")
}

model Account {
  id                           String                 @id @default(cuid())
  email                        String                 @unique
  password                     String
  pinCode                      String?
  fullName                     String
  phone                        String?
  avatarUrl                    String?
  status                       AccountStatus          @default(ACTIVE)
  mustChangePassword           Boolean                @default(true)
  active                       Boolean                @default(true)
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  grantedAt                    DateTime               @default(now())
  accountPermissions           AccountPermission[]
  activityLogs                 ActivityLog[]
  inventoryTransactionsCreated InventoryTransaction[] @relation("InventoryTransactionCreatedBy")
  inviteTokens                 InviteToken[]
  ordersCreated                Order[]                @relation("OrderCreatedBy")
  tenantOrders                 Order[]                @relation("TenantOrders")
  shifts                       Shift[]
  staffSessions                StaffSession[]

  @@index([email])
  @@map("accounts")
}

model PosDevice {
  id                     String                  @id @default(cuid())
  branchId               String
  name                   String
  deviceCode             String                  @unique
  devicePin              String?                 @unique
  deviceToken            String?                 @unique
  setupPinHash           String?                 @map("setup_pin_hash")
  activatedAt            DateTime?               @map("activated_at")
  activationAttempts     Int                     @default(0) @map("activation_attempts")
  deviceTokenHash        String?                 @map("device_token_hash")
  refreshTokenHash       String?                 @map("refresh_token_hash")
  tokenVersion           Int                     @default(0) @map("token_version")
  type                   PosDeviceType
  mode                   PosMode                 @default(CASHIER)
  status                 PosStatus               @default(PENDING_ACTIVATION)
  active                 Boolean                 @default(true)
  lastActive             DateTime?               @map("last_active")
  lastLoginAt            DateTime?               @map("last_login_at")
  currentVersion         String?                 @map("current_version")
  lastFingerprint        String?                 @map("last_fingerprint")
  notes                  String?
  metadata               Json?
  deletedAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deviceFeatureOverrides DeviceFeatureOverride[]
  deviceSessions         DeviceSession[]
  orders                 Order[]
  shifts                 Shift[]
  staffSessions          StaffSession[]
  trustedDevices         TrustedDevice[]

  @@index([deviceCode])
  @@index([deviceToken])
  @@index([status])
  @@index([mode])
  @@index([active])
  @@index([lastActive])
  @@index([branchId])
  @@map("pos_devices")
}

model DeviceSession {
  id               String    @id @default(cuid())
  deviceId         String    @map("device_id")
  tokenHash        String    @map("token_hash")
  refreshTokenHash String?   @map("refresh_token_hash")
  fingerprint      String?   @map("fingerprint")
  deviceName       String?   @map("device_name")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastUsedAt       DateTime? @map("last_used_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  device           PosDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([tokenHash])
  @@index([refreshTokenHash])
  @@index([fingerprint])
  @@index([expiresAt])
  @@map("device_sessions")
}

model TrustedDevice {
  id          String    @id @default(cuid())
  deviceId    String    @map("device_id")
  fingerprint String    @map("fingerprint")
  deviceName  String?   @map("device_name")
  isTrusted   Boolean   @default(true) @map("is_trusted")
  trustedAt   DateTime  @default(now()) @map("trusted_at")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  device      PosDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, fingerprint])
  @@index([deviceId])
  @@index([fingerprint])
  @@map("trusted_devices")
}

model StaffSession {
  id             String    @id @default(cuid())
  accountId      String    @map("account_id")
  deviceId       String    @map("device_id")
  shiftId        String?   @map("shift_id")
  loginAt        DateTime  @default(now()) @map("login_at")
  logoutAt       DateTime? @map("logout_at")
  lastActivityAt DateTime? @map("last_activity_at")
  account        Account   @relation(fields: [accountId], references: [id])
  device         PosDevice @relation(fields: [deviceId], references: [id])
  shift          Shift?    @relation(fields: [shiftId], references: [id])

  @@index([accountId])
  @@index([deviceId])
  @@index([shiftId])
  @@index([loginAt])
  @@index([logoutAt])
  @@map("staff_sessions")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  menuItems   MenuItem[]

  @@index([active])
  @@map("categories")
}

model MenuItem {
  id          String               @id @default(cuid())
  accountId   String
  categoryId  String
  name        String
  price       Decimal              @db.Decimal(10, 2)
  cost        Decimal              @db.Decimal(10, 2)
  description String?
  imageUrl    String?
  available   Boolean              @default(true)
  deletedAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  ingredients MenuItemIngredient[]
  modifiers   MenuItemModifier[]
  category    Category             @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]

  @@index([accountId, categoryId], map: "menu_items_branchId_categoryId_idx")
  @@map("menu_items")
}

model MenuItemModifier {
  id                 String              @id @default(cuid())
  menuItemId         String
  name               String
  minSelect          Int                 @default(0)
  maxSelect          Int                 @default(1)
  price              Decimal             @default(0) @db.Decimal(10, 2)
  sortOrder          Int                 @default(0)
  menuItem           MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  orderItemModifiers OrderItemModifier[]

  @@index([menuItemId])
  @@map("menu_item_modifiers")
}

model MenuItemIngredient {
  id           String     @id @default(cuid())
  menuItemId   String
  ingredientId String
  amount       Decimal    @db.Decimal(10, 2)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
  @@map("menu_item_ingredients")
}

model Ingredient {
  id                    String                 @id @default(cuid())
  accountId             String
  name                  String
  unit                  IngredientUnit
  quantity              Decimal                @default(0) @db.Decimal(10, 2)
  warningQuantity       Decimal                @default(0) @db.Decimal(10, 2)
  maxQuantity           Decimal?               @db.Decimal(10, 2)
  price                 Decimal                @default(0) @db.Decimal(10, 2)
  supplier              String?
  sku                   String?
  location              String?
  barcode               String?
  available             Boolean                @default(true)
  lastUpdated           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  inventoryTransactions InventoryTransaction[]
  menuItems             MenuItemIngredient[]
  orderItems            OrderItem[]
  stockAlerts           StockAlert[]
  stockAudits           StockAudit[]

  @@index([sku])
  @@index([barcode])
  @@index([name])
  @@index([accountId], map: "ingredients_branchId_idx")
  @@map("ingredients")
}

model StockAlert {
  id           String     @id @default(cuid())
  ingredientId String
  branchId     String
  alertType    String     @default("LOW_STOCK")
  threshold    Decimal    @db.Decimal(10, 2)
  message      String?
  isResolved   Boolean    @default(false)
  resolvedAt   DateTime?
  resolvedBy   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@map("stock_alerts")
}

model StockAudit {
  id               String     @id @default(cuid())
  ingredientId     String
  branchId         String
  expectedQuantity Decimal    @db.Decimal(10, 2)
  actualQuantity   Decimal    @db.Decimal(10, 2)
  variance         Decimal    @db.Decimal(10, 2)
  notes            String?
  auditDate        DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  accountId        String
  ingredient       Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([branchId, auditDate])
  @@map("stock_audits")
}

model InventoryTransaction {
  id             String                   @id @default(cuid())
  accountId      String
  ingredientId   String
  createdBy      String
  type           InventoryTransactionType
  quantity       Decimal                  @db.Decimal(10, 2)
  beforeQuantity Decimal?                 @db.Decimal(10, 2)
  afterQuantity  Decimal?                 @db.Decimal(10, 2)
  note           String?
  referenceId    String?
  referenceType  String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  account        Account                  @relation("InventoryTransactionCreatedBy", fields: [createdBy], references: [id])
  ingredient     Ingredient               @relation(fields: [ingredientId], references: [id])

  @@map("inventory_transactions")
}

model Shift {
  id             String         @id @default(cuid())
  branchId       String
  posDeviceId    String?
  accountId      String?
  startTime      DateTime       @default(now())
  endTime        DateTime?
  lastActive     DateTime?
  isOnline       Boolean        @default(true)
  ipAddress      String?
  userAgent      String?
  openingBalance Decimal        @default(0) @db.Decimal(12, 2)
  closingBalance Decimal?       @db.Decimal(12, 2)
  actualBalance  Decimal?       @db.Decimal(12, 2)
  cashSales      Decimal?       @default(0) @db.Decimal(12, 2)
  cardSales      Decimal?       @default(0) @db.Decimal(12, 2)
  otherSales     Decimal?       @default(0) @db.Decimal(12, 2)
  totalOrders    Int?           @default(0)
  note           String?
  status         ShiftStatus    @default(OPEN)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  orders         Order[]
  account        Account?       @relation(fields: [accountId], references: [id])
  posDevice      PosDevice?     @relation(fields: [posDeviceId], references: [id])
  staffSessions  StaffSession[]

  @@index([branchId, accountId])
  @@map("shifts")
}

model Order {
  id                String            @id @default(cuid())
  accountId         String
  posDeviceId       String?
  createdBy         String
  shiftId           String?
  customerId        String?
  orderNumber       String            @unique
  source            String?           @default("POS")
  tableNumber       String?
  tableId           String?           @map("table_id")
  sessionId         String?           @unique @map("session_id")
  status            OrderStatus
  kitchenStatus     KitchenStatus     @default(PENDING)
  paymentMethod     PaymentMethod?
  paymentStatus     PaymentStatus     @default(UNPAID)
  orderType         OrderType
  subtotal          Decimal           @default(0) @db.Decimal(12, 2)
  tax               Decimal           @default(0) @db.Decimal(12, 2)
  taxRate           Decimal?          @db.Decimal(5, 2)
  serviceCharge     Decimal           @default(0) @db.Decimal(12, 2)
  discount          Decimal           @default(0) @db.Decimal(12, 2)
  rounding          Decimal           @default(0) @db.Decimal(12, 2)
  total             Decimal           @default(0) @db.Decimal(12, 2)
  cost              Decimal           @default(0) @db.Decimal(12, 2)
  profit            Decimal           @default(0) @db.Decimal(12, 2)
  note              String?
  guestCount        Int?              @default(1)
  inventoryDeducted Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  completedAt       DateTime?
  deletedAt         DateTime?
  kots              Kot[]
  items             OrderItem[]
  account           Account           @relation("OrderCreatedBy", fields: [createdBy], references: [id])
  tenantAccount     Account           @relation("TenantOrders", fields: [accountId], references: [id])
  customer          Customer?         @relation(fields: [customerId], references: [id])
  posDevice         PosDevice?        @relation(fields: [posDeviceId], references: [id])
  shift             Shift?            @relation(fields: [shiftId], references: [id])
  table             Table?            @relation("TableOrders", fields: [tableId], references: [id])
  session           PlaySession?      @relation("SessionOrder", fields: [sessionId], references: [id])
  payments          Payment[]
  redeemedVouchers  RedeemedVoucher[]

  @@index([shiftId])
  @@index([orderNumber])
  @@index([tableNumber])
  @@index([tableId])
  @@index([accountId, createdAt])
  @@index([accountId, paymentStatus])
  @@index([accountId, status])
  @@index([source, paymentStatus, status])
  @@index([source, deletedAt])
  @@map("orders")
}

model OrderItem {
  id          String              @id @default(cuid())
  orderId     String
  menuItemId  String?
  inventoryId String? @map("inventory_id")
  kotId       String?
  name        String
  price       Decimal             @db.Decimal(12, 2)
  cost        Decimal             @default(0) @db.Decimal(12, 2)
  quantity    Int
  discount    Decimal             @default(0) @db.Decimal(12, 2)
  total       Decimal             @default(0) @db.Decimal(12, 2)
  note        String?
  modifiers   OrderItemModifier[]
  kot         Kot?                @relation(fields: [kotId], references: [id])
  menuItem    MenuItem?           @relation(fields: [menuItemId], references: [id])
  inventory   Ingredient?         @relation(fields: [inventoryId], references: [id])
  order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuItemId])
  @@index([inventoryId])
  @@index([kotId])
  @@map("order_items")
}

model OrderItemModifier {
  id          String            @id @default(cuid())
  orderItemId String
  modifierId  String?
  name        String
  price       Decimal           @default(0) @db.Decimal(10, 2)
  quantity    Int               @default(1)
  modifier    MenuItemModifier? @relation(fields: [modifierId], references: [id])
  orderItem   OrderItem         @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

model Kot {
  id          String        @id @default(cuid())
  orderId     String
  branchId    String
  kotNumber   String        @unique
  status      KitchenStatus @default(PENDING)
  priority    Int           @default(0)
  note        String?
  preparedBy  String?
  preparedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items       OrderItem[]

  @@index([orderId])
  @@index([status])
  @@index([branchId, status])
  @@map("kots")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  status        PaymentStatus
  reference     String?
  transactionId String?
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("payments")
}

model Customer {
  id               String            @id @default(cuid())
  branchId         String
  name             String
  phone            String?
  email            String?
  birthDate        DateTime?
  totalSpent       Decimal           @default(0) @db.Decimal(12, 2)
  visitCount       Int               @default(0)
  lastVisit        DateTime?
  tier             LoyaltyTier       @default(BRONZE)
  points           Int               @default(0)
  note             String?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  loyaltyPoints    LoyaltyPoint[]
  orders           Order[]
  redeemedVouchers RedeemedVoucher[]

  @@unique([branchId, phone])
  @@index([points])
  @@index([branchId, tier])
  @@map("customers")
}

model LoyaltyPoint {
  id         String    @id @default(cuid())
  customerId String
  branchId   String
  points     Int
  type       String    @default("EARN")
  reference  String?
  note       String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
  @@index([branchId, createdAt])
  @@map("loyalty_points")
}

model Voucher {
  id               String            @id @default(cuid())
  branchId         String
  code             String            @unique
  type             VoucherType
  name             String
  description      String?
  discountValue    Decimal           @db.Decimal(12, 2)
  maxDiscount      Decimal?          @db.Decimal(12, 2)
  minOrderValue    Decimal?          @db.Decimal(12, 2)
  usageLimit       Int?              @default(0)
  usedCount        Int               @default(0)
  pointsCost       Int               @default(0)
  startDate        DateTime
  endDate          DateTime
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  redeemedVouchers RedeemedVoucher[]

  @@index([code])
  @@index([startDate, endDate])
  @@index([branchId, isActive])
  @@map("vouchers")
}

model RedeemedVoucher {
  id         String   @id @default(cuid())
  voucherId  String
  customerId String
  orderId    String?
  discount   Decimal  @db.Decimal(12, 2)
  redeemedAt DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])
  order      Order?   @relation(fields: [orderId], references: [id])
  voucher    Voucher  @relation(fields: [voucherId], references: [id])

  @@index([voucherId])
  @@index([customerId])
  @@index([orderId])
  @@map("redeemed_vouchers")
}

model InviteToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  accountId String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@map("invite_tokens")
}

model ActivityLog {
  id          String   @id @default(cuid())
  branchId    String?
  accountId   String?
  posDeviceId String?
  action      String
  module      String
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  account     Account? @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
  @@index([module, action])
  @@index([branchId, createdAt])
  @@map("activity_logs")
}


