# Server
PORT=3001
NODE_ENV=development

# MySQL - Prisma connection string
DATABASE_URL="mysql://root:password@localhost:3306/fnb_store"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS - frontend URL (Vite default)
CORS_ORIGIN=http://localhost:5173

# Seed admin (tạo lần đầu khi chạy seed)
SEED_ADMIN_EMAIL=admin@store.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Quản trị viên

# Tự chạy seed khi khởi động nếu DB trống
AUTO_SEED_ON_START=true
