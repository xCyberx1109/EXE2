# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (Supabase) - Prisma connection string
# Runtime: Transaction mode pooler (port 6543, pgbouncer=true)
#   Thêm &connection_limit=5 và &pool_timeout=10 để tránh pool exhaustion
# Migrations: Session mode pooler / direct connection (port 5432)
#
# Ví dụ:
#   DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=10"
#   DIRECT_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
# Runtime - transaction mode pooler (connection_limit=15, pool_timeout=30)
DATABASE_URL="postgresql://postgres.fmtqvfmhyicsuqsniocn:xCyberPunkx2005@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=15&pool_timeout=30"

# Migrations - session mode pooler (direct)
DIRECT_URL="postgresql://postgres.fmtqvfmhyicsuqsniocn:xCyberPunkx2005@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# POS JWT (riêng cho thiết bị POS)
POS_JWT_SECRET=your-pos-jwt-secret-change-in-production
POS_JWT_EXPIRES_IN=30d

# CORS - comma-separated frontend URLs (dev + production)
# Ví dụ: http://localhost:5173,http://localhost:5174,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Seed admin (tạo lần đầu khi chạy seed)
SEED_ADMIN_EMAIL=admin@store.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Quản trị viên

# Tự chạy seed khi khởi động nếu DB trống
AUTO_SEED_ON_START=true

# Resend - Transactional email service (https://resend.com)
# Get your API key from https://resend.com/api-keys
# Domain must be verified in Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="POS Builders <noreply@pos.builders>"

# QR gọi món
QR_MENU_SECRET=123456789
QR_MENU_EXPIRES_IN=365d